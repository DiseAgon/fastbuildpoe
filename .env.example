# Copy to .env.local and fill in. All values are server-side only.

# Sent on every request to PoE / pobb.in. Use a realistic, identifying UA.
# GGG asks third-party tools to identify themselves and include contact info.
APP_USER_AGENT="FastBuildPOE/0.1 (+contact: your-email@example.com)"

# Optional. Required only for live price fetching (POST search / fetch).
# Get it from your pathofexile.com session cookie. Never commit it.
POESESSID=""

# Optional override of the default league (otherwise auto-detected as the
# current challenge league per game).
DEFAULT_LEAGUE_POE1=""
DEFAULT_LEAGUE_POE2=""
